# Backend Configuration
PORT=3001
NODE_ENV=development

# Backup Storage
# Windows example: C:\Users\User\Downloads
# Linux/Mac example: /home/user/Downloads
# Если оставить пустым — автоматически используется папка Downloads текущего пользователя
BACKUP_ROOT_DIR=

MAX_RETRIES=3
SSH_CONNECT_TIMEOUT=10
FTP_NET_TIMEOUT=10

# Database
DB_PATH=./data/backup.db

# CORS — укажите порт на котором запустился frontend (5173 или 5174)
FRONTEND_URL=http://localhost:5174

# OLVIA FTP Credentials
OLVIA_FTP_LOGIN=122333
OLVIA_FTP_PASSWORD=553721473

# Authorization
# Логин и пароль для входа в веб-интерфейс
AUTH_USERNAME=admin
AUTH_PASSWORD=backup2024
